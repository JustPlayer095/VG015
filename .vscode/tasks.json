{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "start-openocd",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/tools/run_openocd.ps1",
                "-WorkingDirectory",
                "${workspaceFolder}",
                "-InterfaceCfg",
                "${config:workproject.openocdInterfaceCfg}",
                "-TargetCfg",
                "${config:workproject.openocdTargetCfg}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Open On-Chip Debugger",
                    "endsPattern": "Listening on port"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        },
        {
            "label": "bootloader-build",
            "type": "shell",
            "hide": true,
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/tools/run_make.ps1",
                "-WorkingDirectory",
                "${workspaceFolder}/bootloader"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-build",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/tools/run_make.ps1",
                "-WorkingDirectory",
                "${workspaceFolder}/${input:appProjectDir}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "bootloader-build-and-flash",
            "type": "shell",
            "command": "${config:workproject.gdbExe}",
            "args": [
                "${workspaceFolder}/bootloader/build/bootloader.elf",
                "-q",
                "-batch",
                "-ex=set confirm off",
                "-ex=target extended-remote localhost:3333",
                "-ex=monitor reset halt",
                "-ex=load",
                "-ex=monitor reset run",
                "-ex=disconnect",
                "-ex=quit"
            ],
            "options": {
                "cwd": "${workspaceFolder}/bootloader",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "dependsOn": [
                "start-openocd",
                "bootloader-build"
            ],
            "dependsOrder": "sequence",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "setup-toolchain-paths",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/tools/setup_toolchain_env.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-flash-via-bootloader",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "& { if ('${input:appBuildMode}' -eq 'build') { try { & '${workspaceFolder}/tools/run_make.ps1' -WorkingDirectory '${workspaceFolder}/${input:appProjectDir}' -TargetName '${input:appProjectName}'; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE } } catch { exit 1 } }; & '${config:workproject.pythonExe}' '${workspaceFolder}/bootloader/boot.py' '--port' '${config:workproject.bootPort}' '--bin' '${workspaceFolder}/${input:appProjectDir}/build/${input:appProjectName}.bin' '--baud' '${config:workproject.bootBaud}' '--timeout' '${config:workproject.bootTimeout}'; exit $LASTEXITCODE }"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "osdp-filetransfer",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "& { if ('${input:appBuildMode}' -eq 'build') { try { & '${workspaceFolder}/tools/run_make.ps1' -WorkingDirectory '${workspaceFolder}/${input:appProjectDir}' -TargetName '${input:appProjectName}'; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE } } catch { exit 1 } }; & '${config:workproject.pythonExe}' '${workspaceFolder}/tools/osdp_filetransfer.py' '--port' '${config:workproject.osdpPort}' '--baud' '${config:workproject.osdpBaud}' '--addr' '${config:workproject.osdpAddr}' '--frag' '${config:workproject.osdpFrag}' '${workspaceFolder}/${input:appProjectDir}/build/${input:appProjectName}.bin'; exit $LASTEXITCODE }"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
    ],
    "inputs": [
        {
            "id": "appProjectDir",
            "type": "promptString",
            "description": "Папка проекта основного приложения (относительно workspace)",
            "default": "vg015"
        },
        {
            "id": "appProjectName",
            "type": "promptString",
            "description": "Имя выходного файла приложения (без расширения)",
            "default": "vg015"
        },
        {
            "id": "appBuildMode",
            "type": "pickString",
            "description": "Перед запуском собрать приложение?",
            "options": [
                "reuse",
                "build"
            ],
            "default": "reuse"
        }
    ]
}
